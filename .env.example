# =============================================================================
# AI.SEA Platform — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in every value before running locally.
# Never commit .env.local — it is in .gitignore.
#
# Sections:
#   1. Supabase (required — app + Edge Functions)
#   2. Site URL (required — sitemap & canonical links)
#   3. GitHub PAT (recommended — GitHub enrichment)
#   4. Gemini (required for GitHub enrichment)
#   5. Edge Function CORS (required — Supabase secrets, not .env.local)
# =============================================================================


# -----------------------------------------------------------------------------
# 1. SUPABASE
# -----------------------------------------------------------------------------
# Create a free project at https://supabase.com
# All keys are in: Dashboard → your project → Project Settings → API
# -----------------------------------------------------------------------------

# Your project's REST URL — safe to expose to the browser.
# Format: https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Publishable (anon) key — safe to expose to the browser.
# Dashboard → Project Settings → API → Project API keys → anon / public
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJ...your-anon-key

# Service role key — SERVER ONLY. Bypasses Row Level Security.
# Never put this in NEXT_PUBLIC_* or expose it to the client.
# Dashboard → Project Settings → API → Project API keys → service_role
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key


# -----------------------------------------------------------------------------
# 2. SITE URL
# -----------------------------------------------------------------------------
# Absolute base URL of your deployment, no trailing slash.
# Used by: sitemap.ts, canonical tags, hreflang alternates.
# Local:      http://localhost:3000
# Production: https://aisea.builders
# -----------------------------------------------------------------------------

NEXT_PUBLIC_BASE_URL=http://localhost:3000


# -----------------------------------------------------------------------------
# 3. GITHUB PERSONAL ACCESS TOKEN  (optional — but strongly recommended)
# -----------------------------------------------------------------------------
# Used by: supabase/functions/enrich-github  (GitHub enrichment feature)
#
# Without a token: 60 unauthenticated requests/hour — will hit rate limits
#                  for any builder with more than ~15 repos.
# With a token:    5,000 requests/hour — sufficient for all production use.
#
# How to create:
#   1. Go to https://github.com/settings/tokens
#   2. "Generate new token (classic)"  or  "Fine-grained token"
#   3. Classic token: select scope "public_repo" (read-only public repo data)
#      Fine-grained: set "Repository permissions → Contents → Read-only"
#                    and "Account permissions → Followers → Read-only"
#                    for the "All public repositories" resource owner
#   4. Copy the token — GitHub only shows it once.
#
# NOTE: This var is consumed by the Supabase Edge Function, not the Next.js app.
# Set it as a Supabase secret (see Section 5 below) rather than in .env.local.
# It is listed here for documentation purposes.
# -----------------------------------------------------------------------------

GITHUB_PAT=github_pat_...your-token


# -----------------------------------------------------------------------------
# 4. GOOGLE GEMINI API KEY  (required for GitHub enrichment)
# -----------------------------------------------------------------------------
# Used by: supabase/functions/enrich-github
# Model:   gemini-2.5-flash  (low cost; ~25 LLM calls per enrichment run)
#
# How to get a key:
#   1. Go to https://aistudio.google.com/app/apikey
#      (or https://console.cloud.google.com → APIs & Services → Credentials)
#   2. Click "Create API key"
#   3. Select your Google Cloud project (or create one)
#   4. Copy the key.
#
# Free tier: Gemini Flash has a generous free quota.
# Pricing:   https://ai.google.dev/pricing
#
# NOTE: Like GITHUB_PAT, this is consumed by the Edge Function.
# Set it as a Supabase secret (see Section 5). Listed here for docs.
# -----------------------------------------------------------------------------

GEMINI_API_KEY=AIza...your-gemini-key


# =============================================================================
# 5. SUPABASE EDGE FUNCTION SECRETS  (set via CLI, not .env.local)
# =============================================================================
# The following variables are needed by Supabase Edge Functions.
# They must be set as Supabase secrets, not in .env.local, because Edge
# Functions run in Deno on Supabase infrastructure and do not read .env files.
#
# Set them once with the Supabase CLI:
#
#   supabase secrets set \
#     ALLOWED_ORIGIN=https://aisea.builders,http://localhost:3000 \
#     GITHUB_PAT=github_pat_... \
#     GEMINI_API_KEY=AIza...
#
# SUPABASE_URL, SUPABASE_ANON_KEY, and SUPABASE_SERVICE_ROLE_KEY are
# automatically injected by Supabase into every Edge Function — you do NOT
# need to set those manually.
#
# Variable reference:
#
#   ALLOWED_ORIGIN        Comma-separated list of allowed CORS origins.
#                         Example: https://aisea.builders,http://localhost:3000
#                         See: supabase/functions/_shared/cors.ts
#
#   GITHUB_PAT            GitHub Personal Access Token (see Section 3 above).
#
#   GEMINI_API_KEY        Google Gemini API key (see Section 4 above).
#
# Verify secrets are set:
#   supabase secrets list
# =============================================================================
