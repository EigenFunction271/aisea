# Supabase (Builder Directory)
# Create a project at https://supabase.com; keys from Project Settings > API Keys
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Secret key: server/cron/Edge Functions only; never expose to client
# Supabase Dashboard > Project Settings > API Keys > Secret key
SUPABASE_SECRET_KEY=your-secret-key

# Site URL used for sitemap + constructing absolute links
# (e.g. production domain without trailing slash)
NEXT_PUBLIC_BASE_URL=https://www.your-domain.com
